@inherits LayoutComponentBase
@inject NavigationManager Nav
@using SmartTourGuide.Web.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <!-- Thanh App Bar màu Tối dành riêng cho Admin -->
    <MudAppBar Elevation="1" Color="Color.Dark">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6" Class="ml-3">HỆ THỐNG QUẢN TRỊ (ADMIN)</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Class="mr-4">Admin: @context.User.Identity?.Name</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="Logout">Thoát</MudButton>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <!-- Menu bên trái chỉ chứa chức năng Admin -->
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudText Typo="Typo.caption" Class="pa-4">QUẢN LÝ CHUNG</MudText>

            <MudNavLink Href="/admin/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Tổng
                quan</MudNavLink>

                <MudNavLink Href="/admin/approvals" Icon="@Icons.Material.Filled.CheckCircle">Duyệt bài đăng</MudNavLink>

                @* <MudNavLink Href="/admin/tracking" Icon="@Icons.Material.Filled.Map">Bản đồ theo dõi</MudNavLink> *@

                <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">Quản lý User</MudNavLink>

                <MudNavLink Href="/admin/tours" Icon="@Icons.Material.Filled.DirectionsBus">Quản lý Tours</MudNavLink>
            </MudNavMenu>
        </MudDrawer>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
                <!-- Đây là nơi các trang con (Dashboard, Approval...) hiển thị -->
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>

@code {
    bool _drawerOpen = true;
    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await LocalStorage.ClearAsync();
        await ((CustomAuthStateProvider)AuthStateProvider).NotifyUserLogout();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}