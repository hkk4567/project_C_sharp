@page "/"

<PageTitle>Home</PageTitle>

<MudContainer Class="mt-16 px-8">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Hello MudBlazor!</MudText>
    <MudText Align="Align.Center">Chào mừng bạn đến với ứng dụng Smart Tour Guide</MudText>

    <MudGrid Class="mt-8">
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Color="Color.Primary">Địa điểm</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText>Quản lý các địa điểm du lịch của bạn tại đây.</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">Xem ngay</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Color="Color.Secondary">Người dùng</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText>Quản lý thông tin tài khoản và phân quyền.</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true">Chi tiết</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>