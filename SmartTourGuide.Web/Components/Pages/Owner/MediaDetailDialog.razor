@using SmartTourGuide.Shared.DTOs
@using MudBlazor
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject IDialogService MudDialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Poi.Name</MudText>
    </TitleContent>
    <DialogContent>
        @* Tăng trải nghiệm cuộn mượt mà *@
        <MudContainer Style="max-height: 600px; overflow-y: auto" Class="pa-0">

            @if (Poi.ImageUrls != null && Poi.ImageUrls.Any())
            {
                <MudCarousel Class="mud-width-full" Style="height:300px;" ShowArrows="true" ShowBullets="true"
                             AutoCycle="true" TData="string">
                    @foreach (var img in Poi.ImageUrls)
                    {
                        <MudCarouselItem Transition="Transition.Slide">
                            <div class="d-flex align-center justify-center" style="height:100%; background-color: #eee;">
                                <MudImage Src="@CombineUrl(ApiUrl, img)" ObjectFit="ObjectFit.Contain"
                                          Style="width:100%; height:100%;" Alt="@Poi.Name" />
                            </div>
                        </MudCarouselItem>
                    }
                </MudCarousel>
            }
            else
            {
                <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined"
                          ContentAlignment="HorizontalAlignment.Center">
                    Chưa có ảnh mô tả.
                </MudAlert>
            }

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.h6" GutterBottom="true">
                Thông tin thuyết minh @ViewLangLabel
            </MudText>

            @if (Poi.ExistingAudios != null && Poi.ExistingAudios.Any())
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                    Sử dụng file ghi âm gốc.
                </MudAlert>

                @foreach (var audio in Poi.ExistingAudios)
                {
                    <div class="d-flex align-center justify-space-between mb-2 pa-2"
                         style="border: 1px solid #e0e0e0; border-radius: 8px; background: #fafafa;">

                        <div class="d-flex align-center flex-grow-1 mr-2">
                            <audio controls style="width: 100%; height: 40px;">
                                <source src="@CombineUrl(ApiUrl, audio.Url)" type="audio/mpeg">
                            </audio>
                        </div>

                        @* MỚI: Nút Xóa Audio (Chỉ hiện khi Chủ quán xem, ẩn nếu Admin xem) *@
                        @if (!IsReadOnly)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => DeleteAudioAsync(audio))" Title="Xóa file này" />
                        }
                    </div>
                }
            }
            @* Fallback: Phòng trường hợp Backend chưa trả về ExistingAudios mà chỉ có AudioUrls *@
            else if (Poi.AudioUrls != null && Poi.AudioUrls.Any())
            {
                @foreach (var audioUrl in Poi.AudioUrls)
                {
                    <div class="d-flex align-center mb-2 pa-2"
                         style="border: 1px solid #e0e0e0; border-radius: 8px; background: #fafafa;">
                        <audio controls style="width: 100%; height: 40px;">
                            <source src="@CombineUrl(ApiUrl, audioUrl)" type="audio/mpeg">
                        </audio>
                    </div>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Chưa có audio cho địa điểm này. Vào
                    <strong>🎙️ TTS Studio</strong> để tạo thuyết minh.
                </MudAlert>
            }


        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Đóng</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="GoToEdit">Chỉnh sửa</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialogRef { get; set; } = default!;
    [Parameter] public required PoiDto Poi { get; set; }
    [Parameter] public string ApiUrl { get; set; } = "";
    [Parameter] public EventCallback OnEditClicked { get; set; }
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public string ViewLangLabel { get; set; } = ""; // VD: " (en-US)"

    private async Task DeleteAudioAsync(MediaAssetDto audio)
    {
        // 1. Hỏi xác nhận
        bool? confirm = await MudDialogService.ShowMessageBox(
            "Xác nhận xóa",
            "Bạn có chắc chắn muốn xóa file ghi âm này không?",
            yesText: "Xóa ngay", cancelText: "Hủy");

        if (confirm == true)
        {
            try
            {
                // 2. Gọi API để xóa file trên Server
                var response = await Http.DeleteAsync($"api/assets/{audio.Id}");

                if (response.IsSuccessStatusCode)
                {
                    // 3. Cập nhật lại giao diện (Xóa khỏi danh sách)
                    Poi.ExistingAudios.Remove(audio);

                    // Xóa luôn bên AudioUrls để đồng bộ
                    if (Poi.AudioUrls != null && audio.Url != null && Poi.AudioUrls.Contains(audio.Url))
                    {
                        Poi.AudioUrls.Remove(audio.Url);
                    }

                    Snackbar.Add("Đã xóa file Audio thành công!", Severity.Success);

                    // Vẽ lại màn hình Dialog
                    StateHasChanged();
                }
                else
                {
                    Snackbar.Add("Xóa thất bại. Có thể do lỗi mạng.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi kết nối: {ex.Message}", Severity.Error);
            }
        }
    }
    private string CombineUrl(string baseUri, string? relativePath)
    {
        if (string.IsNullOrEmpty(relativePath)) return "";
        if (relativePath.StartsWith("http")) return relativePath;
        return $"{baseUri.TrimEnd('/')}/{relativePath.TrimStart('/')}";
    }

    void Close() => MudDialogRef.Close();

    void GoToEdit()
    {
        MudDialogRef.Close();
        OnEditClicked.InvokeAsync();
    }
}