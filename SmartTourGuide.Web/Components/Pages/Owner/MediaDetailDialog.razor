@using SmartTourGuide.Shared.DTOs
@using MudBlazor
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Poi.Name</MudText>
    </TitleContent>
    <DialogContent>
        @* Tăng trải nghiệm cuộn mượt mà *@
        <MudContainer Style="max-height: 600px; overflow-y: auto" Class="pa-0">

            @if (Poi.ImageUrls != null && Poi.ImageUrls.Any())
            {
                <MudCarousel Class="mud-width-full" Style="height:300px;" ShowArrows="true" ShowBullets="true"
                    AutoCycle="true" TData="string">
                    @foreach (var img in Poi.ImageUrls)
                    {
                        <MudCarouselItem Transition="Transition.Slide">
                            <div class="d-flex align-center justify-center" style="height:100%; background-color: #eee;">
                                <MudImage Src="@CombineUrl(ApiUrl, img)" ObjectFit="ObjectFit.Contain"
                                    Style="width:100%; height:100%;" Alt="@Poi.Name" />
                            </div>
                        </MudCarouselItem>
                    }
                </MudCarousel>
            }
            else
            {
                <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined"
                    ContentAlignment="HorizontalAlignment.Center">
                    Chưa có ảnh mô tả.
                </MudAlert>
            }

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.h6" GutterBottom="true" icon="@Icons.Material.Filled.AudioFile">Thông tin thuyết minh
            </MudText>

            @if (Poi.AudioUrls != null && Poi.AudioUrls.Any())
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                    Sử dụng file ghi âm gốc.
                </MudAlert>

                @foreach (var audio in Poi.AudioUrls)
                {
                    <div class="d-flex align-center mb-2 pa-2"
                        style="border: 1px solid #e0e0e0; border-radius: 8px; background: #fafafa;">
                        <audio controls style="width: 100%; height: 40px;">
                            <source src="@CombineUrl(ApiUrl, audio)" type="audio/mpeg">
                        </audio>
                    </div>
                }
            }
            else
            {
                <MudPaper Class="pa-4" Elevation="0" Outlined="true" Style="background-color: #f9f9f9; border-radius: 8px;">
                    <div class="d-flex justify-space-between align-center mb-3">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Tự động thuyết minh (AI):</MudText>

                        <div class="d-flex gap-2">
                            @if (_isReading)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop"
                                    OnClick="StopSpeaking" Size="Size.Small">Dừng đọc</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Info"
                                    StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="ReadDescription" Size="Size.Small">
                                    Nghe thuyết minh</MudButton>
                            }
                        </div>
                    </div>

                    <MudText Typo="Typo.body2" Style="line-height: 1.7; color: #444;">
                        @(string.IsNullOrWhiteSpace(Poi.Description) ? "Địa điểm này chưa có nội dung mô tả." :
                                            Poi.Description)
                    </MudText>
                </MudPaper>
            }

        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Đóng</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="GoToEdit">Chỉnh sửa</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialogRef { get; set; } = default!;
    [Parameter] public required PoiDto Poi { get; set; }
    [Parameter] public string ApiUrl { get; set; } = "";
    [Parameter] public EventCallback OnEditClicked { get; set; }

    private bool _isReading = false;

    private async Task ReadDescription()
    {
        if (string.IsNullOrWhiteSpace(Poi.Description))
        {
            Snackbar.Add("Không có nội dung để thuyết minh!", Severity.Warning);
            return;
        }

        _isReading = true;
        // Gọi JS đã tối ưu ở bước trước
        await JS.InvokeVoidAsync("blazorTts.speak", Poi.Description);
    }

    private async Task StopSpeaking()
    {
        _isReading = false;
        await JS.InvokeVoidAsync("blazorTts.stop");
    }

    private string CombineUrl(string baseUri, string relativePath)
    {
        if (string.IsNullOrEmpty(relativePath)) return "";
        if (relativePath.StartsWith("http")) return relativePath;
        return $"{baseUri.TrimEnd('/')}/{relativePath.TrimStart('/')}";
    }

    void Close() => MudDialogRef.Close();

    void GoToEdit()
    {
        _ = StopSpeaking();
        MudDialogRef.Close();
        OnEditClicked.InvokeAsync();
    }

    public void Dispose()
    {
        // Fire and forget để đảm bảo tắt tiếng khi đóng dialog
        _ = JS.InvokeVoidAsync("blazorTts.stop");
    }
}