@page "/owner/dashboard"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using SmartTourGuide.Shared.DTOs
@using SmartTourGuide.Web.Services
@attribute [Authorize(Roles = "BoothOwner")]
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject OwnerAnalyticsApiService AnalyticsService
@inject OwnerNotificationService NotificationService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 owner-dashboard-shell">
    <MudPaper Elevation="0" Class="owner-hero pa-6 mb-6">
        <MudText Typo="Typo.overline" Class="owner-kicker">Owner Overview</MudText>
        <MudText Typo="Typo.h4" Class="owner-title">Tổng quan gian hàng</MudText>
        <MudText Typo="Typo.body2" Class="owner-subtitle">Số liệu của riêng bạn được lấy từ hệ thống thật, gồm POI, lượt
            ghé và lịch sử thao tác gần đây.</MudText>
        </MudPaper>

        @if (isLoading)
        {
            <MudPaper Class="pa-6" Style="border-radius: 18px;">
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Đang tải dữ liệu gian hàng...</MudText>
            </MudPaper>
        }
        else if (!string.IsNullOrWhiteSpace(loadError))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">@loadError</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="owner-stat owner-stat-poi pa-4">
                        <div class="d-flex justify-space-between align-start">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="owner-stat-label">Địa điểm của tôi</MudText>
                                <MudText Typo="Typo.h3" Class="owner-stat-value">@summary.TotalPois</MudText>
                            </div>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Class="owner-stat-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Large" />
                            </MudAvatar>
                        </div>
                        <MudText Typo="Typo.caption" Class="owner-stat-caption">Tổng POI thuộc quyền quản lý của bạn</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="owner-stat owner-stat-visits pa-4">
                        <div class="d-flex justify-space-between align-start">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="owner-stat-label">Tổng lượt ghé</MudText>
                                <MudText Typo="Typo.h3" Class="owner-stat-value">@summary.TotalListensMonth</MudText>
                            </div>
                            <MudAvatar Color="Color.Success" Variant="Variant.Outlined" Class="owner-stat-icon">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Large" />
                            </MudAvatar>
                        </div>
                        <MudText Typo="Typo.caption" Class="owner-stat-caption">30 ngày gần nhất</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="owner-stat owner-stat-heard pa-4">
                        <div class="d-flex justify-space-between align-start">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="owner-stat-label">Địa điểm đã được ghé</MudText>
                                <MudText Typo="Typo.h3" Class="owner-stat-value">@summary.DistinctPoisHeard</MudText>
                            </div>
                            <MudAvatar Color="Color.Warning" Variant="Variant.Outlined" Class="owner-stat-icon">
                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Large" />
                            </MudAvatar>
                        </div>
                        <MudText Typo="Typo.caption" Class="owner-stat-caption">Số POI đã có lượt nghe thực tế</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="3" Class="owner-stat owner-stat-notify pa-4">
                        <div class="d-flex justify-space-between align-start">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="owner-stat-label">Thông báo mới</MudText>
                                <MudText Typo="Typo.h3" Class="owner-stat-value">@unreadNotifications</MudText>
                            </div>
                            <MudAvatar Color="Color.Info" Variant="Variant.Outlined" Class="owner-stat-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Large" />
                            </MudAvatar>
                        </div>
                        <MudText Typo="Typo.caption" Class="owner-stat-caption">Chưa đọc trong hộp thông báo</MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="8" Class="mt-4">
                    <MudPaper Elevation="3" Class="pa-5 owner-panel owner-chart-panel">
                        <MudText Typo="Typo.h6" Class="section-title mb-4">Tổng lượt ghé 7 ngày gần nhất</MudText>

                        @if (chartSeries.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Chưa có dữ liệu lượt ghé trong 7 ngày gần đây.
                            </MudText>
                        }
                        else
                        {
                            <MudChart ChartType="ChartType.Line" ChartSeries="@chartSeries" XAxisLabels="@chartLabels" Width="100%"
                                      Height="380px" ChartOptions="@chartOptions" />
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="4" Class="mt-4">
                    <MudPaper Elevation="3" Class="pa-5 owner-panel h-100">
                        <div class="d-flex justify-space-between align-center mb-4">
                            <MudText Typo="Typo.h6" Class="section-title">Hoạt động gần đây</MudText>
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                @recentActivities.Count mục</MudChip>
                            </div>

                            @if (recentActivities.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">Chưa có hoạt động phù hợp.</MudText>
                            }
                            else
                            {
                                <MudTimeline TimelinePosition="TimelinePosition.Start" Class="ml-n6 owner-timeline">
                                    @foreach (var activity in recentActivities)
                                    {
                                        <MudTimelineItem Color="@GetActivityColor(activity.ActivityType)" Size="Size.Small">
                                            <ItemOpposite>
                                                <MudText Typo="Typo.caption" Class="activity-time">@GetRelativeTime(activity.Timestamp)
                                                </MudText>
                                            </ItemOpposite>
                                            <ItemContent>
                                                <MudText Typo="Typo.body2" Class="activity-title">@GetActivityLabel(activity.ActivityType)
                                                </MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@activity.Description</MudText>
                                            </ItemContent>
                                        </MudTimelineItem>
                                    }
                                </MudTimeline>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
        </MudContainer>

@code {
    private readonly ChartOptions chartOptions = new()
    {
        InterpolationOption = InterpolationOption.NaturalSpline,
        LineStrokeWidth = 3,
        YAxisLines = true,
        YAxisTicks = 25
    };

    private OwnerAnalyticsSummaryDto summary = new();
    private List<OwnerDailyListenDto> dailyListens = new();
    private List<ChartSeries> chartSeries = new();
    private string[] chartLabels = Array.Empty<string>();
    private List<ActivityLogDto> recentActivities = new();
    private int unreadNotifications;
    private int ownerId;
    private string username = string.Empty;
    private bool isLoading = true;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            username = await LocalStorage.GetItemAsync<string>("username") ?? string.Empty;
            var ownerIdValue = await LocalStorage.GetItemAsync<string>("userId");
            ownerId = int.TryParse(ownerIdValue, out var parsedOwnerId) ? parsedOwnerId : 0;

            if (ownerId <= 0 || string.IsNullOrWhiteSpace(username))
            {
                loadError = "Không tìm thấy thông tin đăng nhập của owner.";
                return;
            }

            var summaryTask = SafeAsync(() => AnalyticsService.GetSummaryAsync(ownerId));
            var dailyTask = SafeAsync(() => AnalyticsService.GetDailyListensAsync(ownerId, 7));
            var notificationTask = SafeAsync(() => NotificationService.GetOwnerNotificationsAsync());
            var activityTask = LoadRecentActivitiesAsync(username);

            await Task.WhenAll(summaryTask, dailyTask, notificationTask, activityTask);

            summary = await summaryTask ?? new OwnerAnalyticsSummaryDto();
            dailyListens = await dailyTask ?? new List<OwnerDailyListenDto>();
            unreadNotifications = (await notificationTask)?.UnreadCount ?? 0;

            var rawActivities = await activityTask;
            recentActivities = FilterRelevantActivities(rawActivities)
                .Take(5)
                .ToList();

            if (recentActivities.Count == 0)
            {
                recentActivities = rawActivities.Take(5).ToList();
            }

            BuildChart();
        }
        catch (Exception ex)
        {
            loadError = $"Không tải được dashboard owner: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BuildChart()
    {
        chartLabels = dailyListens.Select(x => x.Date.ToString("dd/MM")).ToArray();

        chartSeries = new List<ChartSeries>
        {
            new()
            {
                Name = "Tổng lượt ghé",
                Data = dailyListens.Select(x => (double)x.ListenCount).ToArray()
            }
        };
    }

    private static async Task<T?> SafeAsync<T>(Func<Task<T?>> action) where T : class
    {
        try
        {
            return await action();
        }
        catch
        {
            return null;
        }
    }

    private async Task<List<ActivityLogDto>> LoadRecentActivitiesAsync(string currentUsername)
    {
        var query = new Dictionary<string, string?>
        {
            ["user"] = currentUsername,
            ["from"] = DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd")
        };

        var url = QueryHelpers.AddQueryString("api/activitylogs", query);
        return await SafeAsync(() => Http.GetFromJsonAsync<List<ActivityLogDto>>(url)) ?? new List<ActivityLogDto>();
    }

    private static IEnumerable<ActivityLogDto> FilterRelevantActivities(IEnumerable<ActivityLogDto> activities)
    {
        return activities.Where(activity =>
            activity.ActivityType.Contains("CreatePOI", StringComparison.OrdinalIgnoreCase) ||
            activity.ActivityType.Contains("UpdatePOI", StringComparison.OrdinalIgnoreCase) ||
            activity.ActivityType.Contains("SavePoiTranslation", StringComparison.OrdinalIgnoreCase) ||
            activity.ActivityType.Contains("SaveTourTranslation", StringComparison.OrdinalIgnoreCase) ||
            activity.ActivityType.Contains("CreateTour", StringComparison.OrdinalIgnoreCase));
    }

    private static Color GetActivityColor(string activityType)
    {
        if (activityType.Contains("CreatePOI", StringComparison.OrdinalIgnoreCase)) return Color.Success;
        if (activityType.Contains("UpdatePOI", StringComparison.OrdinalIgnoreCase)) return Color.Info;
        if (activityType.Contains("SavePoiTranslation", StringComparison.OrdinalIgnoreCase)) return Color.Warning;
        if (activityType.Contains("SaveTourTranslation", StringComparison.OrdinalIgnoreCase)) return Color.Warning;
        if (activityType.Contains("CreateTour", StringComparison.OrdinalIgnoreCase)) return Color.Primary;

        return Color.Info;
    }

    private static string GetActivityLabel(string activityType)
    {
        if (activityType.Contains("CreatePOI", StringComparison.OrdinalIgnoreCase)) return "Thêm địa điểm mới";
        if (activityType.Contains("UpdatePOI", StringComparison.OrdinalIgnoreCase)) return "Cập nhật địa điểm";
        if (activityType.Contains("SavePoiTranslation", StringComparison.OrdinalIgnoreCase)) return "Thêm / cập nhật ngôn ngữ cho POI";
        if (activityType.Contains("SaveTourTranslation", StringComparison.OrdinalIgnoreCase)) return "Thêm / cập nhật ngôn ngữ cho Tour";
        if (activityType.Contains("CreateTour", StringComparison.OrdinalIgnoreCase)) return "Tạo tour mới";

        return activityType;
    }

    private static string GetRelativeTime(DateTime timestamp)
    {
        var diff = DateTime.Now - timestamp;

        if (diff.TotalMinutes < 1) return "Vừa xong";
        if (diff.TotalMinutes < 60) return $"{Math.Floor(diff.TotalMinutes)} phút trước";
        if (diff.TotalHours < 24) return $"{Math.Floor(diff.TotalHours)} giờ trước";
        if (diff.TotalDays < 7) return $"{Math.Floor(diff.TotalDays)} ngày trước";

        return timestamp.ToString("dd/MM/yyyy");
    }
}

