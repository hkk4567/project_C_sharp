@page "/owner/my-pois"
@using SmartTourGuide.Shared.DTOs
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@attribute [Authorize(Roles = "BoothOwner")]

<style>
    .lang-switcher {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .ls-btn {
        padding: 5px 14px;
        border-radius: 99px;
        cursor: pointer;
        font-size: .8rem;
        font-weight: 600;
        border: 1.5px solid var(--mud-palette-divider);
        background: var(--mud-palette-background);
        color: var(--mud-palette-text-secondary);
        transition: all .15s;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .ls-btn:hover {
        border-color: var(--mud-palette-primary);
        color: var(--mud-palette-primary);
    }

    .ls-btn.active {
        background: var(--mud-palette-primary);
        border-color: var(--mud-palette-primary);
        color: #fff;
        box-shadow: 0 2px 8px rgba(0, 0, 0, .15);
    }

    .poi-translated {
        font-size: .72rem;
        opacity: .6;
        margin-top: 2px;
    }
</style>

<!-- HEADER -->
<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h4">Địa Điểm Của Tôi</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/owner/create-poi"))">
        Tạo mới
    </MudButton>
</MudStack>

<!-- LANG SWITCHER -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
    <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" Style="opacity:.6;" />
    <MudText Typo="Typo.caption" Style="opacity:.7; font-weight:600;">Hiển thị ngôn ngữ:</MudText>
    <div class="lang-switcher">
        @foreach (var lang in _langs)
        {
            <div class="ls-btn @(_viewLang == lang.Code ? "active" : "")"                 @onclick="() => SwitchViewLang(lang.Code)">
                <span>@lang.Flag</span>
                <span>@lang.Name</span>
            </div>
        }
    </div>
    @if (_loadingTranslations)
    {
        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
    }
</MudStack>

<MudTable Items="@pois" Hover="true" Loading="@_loading" Striped="true" Elevation="3">
    <HeaderContent>
        <MudTh>Media</MudTh>
        <MudTh>Tên địa điểm</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh>Vị trí</MudTh>
        <MudTh Style="text-align:right">Hành động</MudTh>
    </HeaderContent>
    <RowTemplate>

        <!-- CỘT MEDIA -->
        <MudTd DataLabel="Media">
            @if (context.ImageUrls != null && context.ImageUrls.Count > 0)
            {
                <MudTooltip Text="Bấm để xem chi tiết ảnh & audio">
                    <MudImage Src="@($"{ApiUrl}{context.ImageUrls[0]}")" Width="80" Height="60"                              ObjectFit="ObjectFit.Cover"
                              Class="rounded cursor-pointer"                              @onclick="@(() => OpenMediaDialog(context))" />
                </MudTooltip>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" Color="Color.Default" />
            }

            <div class="mt-1">
                @if (_viewLang == "vi-VN")
                {
                    @* vi-VN: dùng GetAudiosForLang để lọc đúng từ ExistingAudios *@
                    @if (GetAudiosForLang(context).Count > 0)
                    {
                        <MudChip T="string" Color="Color.Info" Size="Size.Small"                                 Icon="@Icons.Material.Filled.Mic">
                            @GetAudiosForLang(context).Count audio (vi)
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small"
                                 Icon="@Icons.Material.Filled.RecordVoiceOver">Đọc TTS</MudChip>
                    }
                }
                else
                {
                    @if (GetAudiosForLang(context).Count > 0)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small"                                 Icon="@Icons.Material.Filled.VolumeUp">
                            @GetAudiosForLang(context).Count audio (@GetLangShort(_viewLang))
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small"                                 Icon="@Icons.Material.Filled.VolumeOff">Chưa
                            có audio</MudChip>
                        }
                    }
                </div>
            </MudTd>

            <!-- CỘT TÊN -->
            <MudTd DataLabel="Tên">
                <MudText Typo="Typo.subtitle1" Style="font-weight:bold;">@GetDisplayName(context)</MudText>
                @if (HasTranslatedName(context))
                {
                    <div class="poi-translated">🌐 @context.Name</div>
                }
                <MudText Typo="Typo.caption">@GetDisplayAddress(context)</MudText>
                <MudText Typo="Typo.caption" Style="opacity:.5;">ID: @context.Id</MudText>
            </MudTd>

            <!-- TRẠNG THÁI -->
            <MudTd DataLabel="Trạng thái">
                @if (context.Status == "Active")
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Đã duyệt</MudChip>
                }
                else if (context.Status == "Pending")
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">Đang chờ</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Từ chối</MudChip>
                }
            </MudTd>

            <!-- VỊ TRÍ -->
            <MudTd DataLabel="Vị trí">
                <MudText Typo="Typo.body2">Lat: @context.Latitude</MudText>
                <MudText Typo="Typo.body2">Long: @context.Longitude</MudText>
            </MudTd>

            <!-- HÀNH ĐỘNG -->
            <MudTd DataLabel="Hành động" Style="text-align:right">
                <MudStack Row="true" Justify="Justify.FlexEnd">
                    <MudIconButton Icon="@Icons.Material.Filled.PermMedia"                               Color="Color.Tertiary" title="Xem Ảnh & Audio"
                                   OnClick="@(() => OpenMediaDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.RecordVoiceOver"                               Color="Color.Secondary"
                                   title="TTS Studio & Bản dịch"                               OnClick="@(() => Nav.NavigateTo($"/tts-studio/{context.Id}"))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"                               Color="Color.Primary" title="Sửa thông tin"
                                   OnClick="@(() => Nav.NavigateTo($"/owner/edit-poi/{context.Id}"))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"                               Color="Color.Error" title="Xóa"
                                   OnClick="@(async (MouseEventArgs e) => await DeletePoi(context))" />
                </MudStack>
            </MudTd>

        </RowTemplate>
        <NoRecordsContent>
            <MudText>Bạn chưa có địa điểm nào.</MudText>
        </NoRecordsContent>
    </MudTable>

@code {
    private List<PoiDto> pois = new();
    private bool _loading = true;
    private bool _loadingTranslations = false;
    private string ApiUrl = "http://localhost:5277";
    private string _viewLang = "vi-VN";

    private Dictionary<string, PoiTranslationDto> _transCache = new();

    private readonly List<(string Code, string Name, string Flag)> _langs = new()
    {
        ("vi-VN", "Việt", "🇻🇳"),
        ("en-US", "English", "🇺🇸"),
        ("ja-JP", "日本語", "🇯🇵"),
        ("ko-KR", "한국어", "🇰🇷"),
    };

    // ── INIT ──────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            var userId = await LocalStorage.GetItemAsync<int>("userId");
            if (userId > 0)
            {
                var result = await Http.GetFromJsonAsync<List<PoiDto>>($"api/pois/owner/{userId}");
                pois = result ?? new();
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi: " + ex.Message, Severity.Error); }
        finally { _loading = false; }
    }

    // ── CHUYỂN NGÔN NGỮ XEM ───────────────────────────────────────────────
    private async Task SwitchViewLang(string lang)
    {
        _viewLang = lang;
        if (lang == "vi-VN") return;

        _loadingTranslations = true;
        StateHasChanged();
        try
        {
            var tasks = pois.Select(async p =>
            {
                var key = $"{p.Id}_{lang}";
                if (_transCache.ContainsKey(key)) return;
                try
                {
                    var t = await Http.GetFromJsonAsync<PoiTranslationDto>(
                        $"api/translations/{p.Id}/{lang}");
                    if (t != null)
                    {
                        t.PoiId = p.Id; t.LanguageCode = lang;
                        _transCache[key] = t;
                    }
                }
                catch { }
            });
            await Task.WhenAll(tasks);
        }
        catch (Exception ex) { Snackbar.Add("Lỗi tải bản dịch: " + ex.Message, Severity.Warning); }
        finally { _loadingTranslations = false; }
    }

    // ── HELPERS ───────────────────────────────────────────────────────────
    private PoiTranslationDto? GetCached(PoiDto poi)
        => _transCache.TryGetValue($"{poi.Id}_{_viewLang}", out var t) ? t : null;

    private string GetDisplayName(PoiDto poi)
    {
        var t = GetCached(poi);
        return (_viewLang != "vi-VN" && !string.IsNullOrEmpty(t?.Name)) ? t!.Name : poi.Name;
    }

    private string GetDisplayDescription(PoiDto poi)
    {
        var t = GetCached(poi);
        return (_viewLang != "vi-VN" && !string.IsNullOrEmpty(t?.Description)) ? t!.Description : poi.Description;
    }

    private string GetDisplayAddress(PoiDto poi)
    {
        var t = GetCached(poi);
        return (_viewLang != "vi-VN" && !string.IsNullOrEmpty(t?.Address)) ? t!.Address : poi.Address;
    }

    // FIX: vi-VN lọc ExistingAudios theo LanguageCode == "vi-VN"
    // Không dùng toàn bộ ExistingAudios (chứa cả en-US, ja-JP...)
    private List<string> GetAudiosForLang(PoiDto poi)
    {
        if (_viewLang == "vi-VN")
            return poi.ExistingAudios?
                       .Where(a => a.LanguageCode == "vi-VN" && !string.IsNullOrEmpty(a.Url))
                       .Select(a => a.Url!)
                       .ToList()
                   ?? new();

        var t = GetCached(poi);
        if (t?.Audios?.Count > 0)
            return t.Audios.Where(a => !string.IsNullOrEmpty(a.Url)).Select(a => a.Url!).ToList();

        return new();
    }

    // Helper lấy ExistingAudios đã lọc theo ngôn ngữ (dùng cho Dialog)
    private List<MediaAssetDto> GetExistingAudiosForLang(PoiDto poi)
    {
        if (_viewLang == "vi-VN")
            return poi.ExistingAudios?
                       .Where(a => a.LanguageCode == "vi-VN")
                       .ToList()
                   ?? new();

        var t = GetCached(poi);
        return t?.Audios ?? new();
    }

    private bool HasTranslatedName(PoiDto poi)
    {
        var t = GetCached(poi);
        return _viewLang != "vi-VN" && !string.IsNullOrEmpty(t?.Name);
    }

    private static string GetLangShort(string code) => code.Split('-')[0].ToLower();

    // ── DIALOG ────────────────────────────────────────────────────────────
    private async Task OpenMediaDialog(PoiDto poi)
    {
        var audiosForLang = GetExistingAudiosForLang(poi);

        var poiForDialog = new PoiDto
        {
            Id = poi.Id,
            Name = GetDisplayName(poi),
            Description = GetDisplayDescription(poi),
            Address = GetDisplayAddress(poi),
            Latitude = poi.Latitude,
            Longitude = poi.Longitude,
            Status = poi.Status,
            OwnerId = poi.OwnerId,
            ImageUrls = poi.ImageUrls,
            // FIX: chỉ truyền audio đúng ngôn ngữ đang xem vào dialog
            AudioUrls = audiosForLang.Select(a => a.Url ?? "").Where(u => !string.IsNullOrEmpty(u)).ToList(),
            ExistingAudios = audiosForLang
        };

        var parameters = new DialogParameters<MediaDetailDialog>
        {
            { x => x.Poi, poiForDialog },
            { x => x.ApiUrl, ApiUrl },
            { x => x.IsReadOnly, false },
            { x => x.ViewLangLabel, _viewLang != "vi-VN" ? $" ({_viewLang})" : "" },
            { x => x.OnEditClicked, EventCallback.Factory.Create(this,
                () => Nav.NavigateTo($"/owner/edit-poi/{poi.Id}")) }
        };

        await DialogService.ShowAsync<MediaDetailDialog>(
            poiForDialog.Name,
            parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    // ── CRUD ──────────────────────────────────────────────────────────────
    private async Task DeletePoi(PoiDto poi)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Xác nhận xóa",
            $"Bạn có chắc muốn xóa địa điểm '{poi.Name}' không?",
            yesText: "Xóa", cancelText: "Hủy");

        if (result == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/pois/{poi.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Đã xóa thành công!", Severity.Success);
                    pois.Remove(poi);
                    var keys = _transCache.Keys.Where(k => k.StartsWith($"{poi.Id}_")).ToList();
                    foreach (var k in keys) _transCache.Remove(k);
                }
                else
                    Snackbar.Add(await response.Content.ReadAsStringAsync(), Severity.Warning);
            }
            catch (Exception ex) { Snackbar.Add("Lỗi server: " + ex.Message, Severity.Error); }
        }
    }
}