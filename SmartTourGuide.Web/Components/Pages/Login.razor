@page "/login"
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject ISnackbar Snackbar
@using SmartTourGuide.Web.Services
@using SmartTourGuide.Shared.DTOs
@using SmartTourGuide.Shared.Enums
@using System.Net.Http.Json

<!-- Phần HTML giữ nguyên như cũ -->
<MudGrid Justify="Justify.Center" Class="mt-10">
    <MudItem xs="12" sm="6" md="4">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Đăng Nhập Hệ Thống</MudText>
                <!-- Loading khi đang kiểm tra đăng nhập tự động -->
                @if (_checkingAutoLogin)
                {
                    <MudAlert Severity="Severity.Info">Đang kiểm tra trạng thái đăng nhập...</MudAlert>
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" />
                }
                else
                {
                    <MudTextField @bind-Value="username" Label="Tên đăng nhập" Variant="Variant.Outlined"
                        Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />

                    <MudTextField @bind-Value="password" Label="Mật khẩu" Variant="Variant.Outlined"
                        InputType="InputType.Password" Class="mt-4" Adornment="Adornment.Start"
                        AdornmentIcon="@Icons.Material.Filled.Lock" OnKeyDown="EnterKeyCheck" />
                }
            </MudCardContent>

            @if (!_checkingAutoLogin)
            {
                <MudCardActions>
                    <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                        OnClick="HandleLogin" Disabled="@_processing">
                        @if (_processing)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <MudText Class="ms-2">Đang xử lý...</MudText>
                        }
                        else
                        {
                            <MudText>Đăng nhập</MudText>
                        }
                    </MudButton>
                </MudCardActions>
            }
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private bool _processing = false;
    private bool _checkingAutoLogin = true; // Cờ hiệu để hiển thị loading lúc mới vào

    protected override async Task OnInitializedAsync()
    {
        // 1. Kiểm tra xem trong LocalStorage có thông tin user cũ không
        try
        {
            var storedRole = await LocalStorage.GetItemAsync<string>("userRole");
            var storedUsername = await LocalStorage.GetItemAsync<string>("username");

            if (!string.IsNullOrEmpty(storedRole) && !string.IsNullOrEmpty(storedUsername))
            {
                // 2. Nếu có, phục hồi trạng thái đăng nhập ngay lập tức
                var authProvider = (CustomAuthStateProvider)AuthStateProvider;
                authProvider.NotifyUserLogin(storedUsername, storedRole);

                // 3. Kiểm tra xem có ReturnUrl không (Url mà user định vào trước khi bị đá ra)
                var uri = Nav.ToAbsoluteUri(Nav.Uri);
                string returnUrl = "";

                if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("ReturnUrl", out var url))
                {
                    returnUrl = url.ToString() ?? "";
                }

                // 4. Nếu có ReturnUrl thì ưu tiên chuyển về đó
                if (!string.IsNullOrEmpty(returnUrl))
                {
                    Nav.NavigateTo(returnUrl);
                }
                else
                {
                    // Nếu không, chuyển về trang mặc định theo role
                    NavigateBasedOnRole(storedRole);
                }

                return; // Kết thúc hàm, không cho hiện form login nữa
            }
        }
        catch
        {
            // Lỗi đọc localstorage hoặc chưa từng đăng nhập -> Kệ nó, hiện form login
        }

        // Tắt loading để hiện form nhập liệu
        _checkingAutoLogin = false;
    }

    // Tách hàm điều hướng ra để dùng chung
    private void NavigateBasedOnRole(string roleStr)
    {
        if (roleStr == "Admin")
            Nav.NavigateTo("/admin/approvals");
        else if (roleStr == "BoothOwner")
            Nav.NavigateTo("/owner/create-poi");
        else
            Nav.NavigateTo("/");
    }

    private async Task EnterKeyCheck(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            Snackbar.Add("Vui lòng nhập đầy đủ thông tin!", Severity.Warning);
            return;
        }

        _processing = true;

        try
        {
            var loginDto = new LoginDto { Username = username, Password = password };
            var response = await Http.PostAsJsonAsync("api/auth/login", loginDto);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (result != null && result.User != null)
                {
                    string roleStr = ((UserRole)result.User.Role).ToString();

                    await LocalStorage.SetItemAsync("authToken", "fake-jwt-token");
                    await LocalStorage.SetItemAsync("username", result.User.Username);
                    await LocalStorage.SetItemAsync("userRole", roleStr);
                    await LocalStorage.SetItemAsync("userId", result.User.Id);

                    var authProvider = (CustomAuthStateProvider)AuthStateProvider;
                    authProvider.NotifyUserLogin(result.User.Username, roleStr);

                    Snackbar.Add("Đăng nhập thành công!", Severity.Success);

                    await Task.Delay(100);

                    // Gọi hàm điều hướng
                    NavigateBasedOnRole(roleStr);
                }
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Đăng nhập thất bại: {errorMsg}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            Snackbar.Add("Không thể kết nối đến Server.", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    public class LoginResponse
    {
        public string Message { get; set; } = string.Empty;
        public UserInfo? User { get; set; }
    }

    public class UserInfo
    {
        public int Id { get; set; }
        public string Username { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public int Role { get; set; }
    }

    public enum UserRole { Tourist = 0, BoothOwner = 1, Admin = 2 }
}