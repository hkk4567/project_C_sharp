@page "/login"
@page "/"
@layout Layout.LoginLayout
@* <--- Thêm chữ Layout. vào đây để trỏ chính xác *@
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject ISnackbar Snackbar
@using SmartTourGuide.Web.Services
@using SmartTourGuide.Shared.DTOs
@using SmartTourGuide.Shared.Enums
@using System.Net.Http.Json

<PageTitle>Đăng Nhập</PageTitle>

<MudCard Elevation="8" Class="pa-8" Style="width: 420px; border-radius: 16px;">

    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 800; color: #333;" Class="mb-8">
        Login
    </MudText>

    @if (_checkingAutoLogin)
    {
        <div class="d-flex flex-column align-center justify-center py-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" Class="mb-4" />
            <MudText Style="color: gray;">Đang kiểm tra phiên đăng nhập...</MudText>
        </div>
    }
    else
    {
        <MudText Typo="Typo.body2" Class="mb-1" Style="color: black;"><b>Username</b></MudText>
        <MudTextField @bind-Value="username" Placeholder="Type your username" Variant="Variant.Text"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" IconSize="Size.Small" Class="mb-4" />

        <MudText Typo="Typo.body2" Class="mb-1" Style="color: black;"> <b>Password</b></MudText>
        <MudTextField @bind-Value="password" Placeholder="Type your password" InputType="InputType.Password"
                      Variant="Variant.Text" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                      IconSize="Size.Small" OnKeyDown="EnterKeyCheck" />

        <div class="d-flex justify-end mt-2 mb-8">
        </div>

        <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="HandleLogin" Disabled="@_processing"                   Class="py-3 mb-8"
                   Style="border-radius: 30px; background: linear-gradient(to right, #29ffc6, #a13bf7); color: white; font-weight: bold; border: none;">
            @if (_processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" Style="color: white;" />
                <MudText Class="ms-2" Style="color: white; font-weight: bold;">Đang xử lý...</MudText>
            }
            else
            {
                <MudText Style="color: white; font-weight: bold;">LOGIN</MudText>
            }
        </MudButton>
    }

</MudCard>

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private bool _processing = false;
    private bool _checkingAutoLogin = true;

    // Không đọc localStorage trong OnInitializedAsync — lỗi JS interop khi prerendering
    private bool _autoLoginChecked = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _autoLoginChecked) return;
        _autoLoginChecked = true;

        try
        {
            var storedRole = await LocalStorage.GetItemAsync<string>("userRole");
            var storedUsername = await LocalStorage.GetItemAsync<string>("username");

            if (!string.IsNullOrEmpty(storedRole) && !string.IsNullOrEmpty(storedUsername))
            {
                // ✅ Set header trên HttpClient (scoped = tồn tại suốt circuit)
                Http.DefaultRequestHeaders.Remove("X-User-Name");
                Http.DefaultRequestHeaders.Add("X-User-Name", storedUsername);

                var authProvider = (CustomAuthStateProvider)AuthStateProvider;
                authProvider.NotifyUserLogin(storedUsername, storedRole);

                NavigateBasedOnRole(storedRole);
                return;
            }
        }
        catch { /* Bỏ qua lỗi storage */ }

        _checkingAutoLogin = false;
        StateHasChanged();
    }

    private void NavigateBasedOnRole(string roleStr)
    {
        // QUAN TRỌNG: Không được điều hướng về "/" vì sẽ bị lặp trang Login
        if (roleStr == "Admin")
            Nav.NavigateTo("/admin/dashboard");
        else if (roleStr == "BoothOwner")
            Nav.NavigateTo("/owner/dashboard");
        else
            // Nếu là khách (Tourist), bạn nên dẫn họ đến một trang danh sách địa điểm
            // hoặc trang dashboard dành cho khách. Tạm thời mình để admin dashboard để bạn test.
            Nav.NavigateTo("/admin/dashboard");
    }

    private async Task EnterKeyCheck(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            Snackbar.Add("Vui lòng nhập đầy đủ thông tin!", Severity.Warning);
            return;
        }

        _processing = true;
        try
        {
            var loginDto = new LoginDto { Username = username, Password = password };
            var response = await Http.PostAsJsonAsync("api/auth/login", loginDto);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (result?.User != null)
                {
                    string roleStr = ((UserRole)result.User.Role).ToString();

                    await LocalStorage.SetItemAsync("authToken", "fake-jwt-token");
                    await LocalStorage.SetItemAsync("username", result.User.Username);
                    await LocalStorage.SetItemAsync("userRole", roleStr);
                    await LocalStorage.SetItemAsync("userId", result.User.Id);

                    // ✅ Set header ngay sau login — HttpClient scoped nên tồn tại suốt session
                    Http.DefaultRequestHeaders.Remove("X-User-Name");
                    Http.DefaultRequestHeaders.Add("X-User-Name", result.User.Username);

                    var authProvider = (CustomAuthStateProvider)AuthStateProvider;
                    authProvider.NotifyUserLogin(result.User.Username, roleStr);

                    Snackbar.Add("Đăng nhập thành công!", Severity.Success);

                    // Delay nhỏ để kịp lưu Storage trước khi nhảy trang
                    await Task.Delay(100);
                    NavigateBasedOnRole(roleStr);
                }
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Thất bại: {errorMsg}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi kết nối Server.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
        finally { _processing = false; }
    }

    // Các class DTO giữ nguyên phía dưới...
    public class LoginResponse { public string Message { get; set; } = ""; public UserInfo? User { get; set; } }
    public class UserInfo
    {
        public int Id { get; set; }
        public string Username { get; set; } = ""; public int Role
        {
            get;
            set;
        }
    }
    public enum UserRole { Tourist = 0, BoothOwner = 1, Admin = 2 }
}