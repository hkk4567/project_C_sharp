@page "/admin/users"
@using SmartTourGuide.Shared.DTOs
@using SmartTourGuide.Shared.Enums
@using SmartTourGuide.Web.Components.Shared
@layout AdminLayout
@inject HttpClient Http
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@attribute [Authorize(Roles = "Admin")]
<style>     /* ===== SEARCH INPUT ===== */

.search-input .mud-input-root{
    border-radius:10px;
}

/* chữ khi nhập */

.mud-theme-dark .search-input input{

    color:#ffffff !important;

    font-weight:500;

}

/* placeholder */

.mud-theme-dark .search-input input::placeholder{

    color:rgba(255,255,255,0.75) !important;

}

/* icon search */

.mud-theme-dark .search-input .mud-input-adornment{

    color:rgba(255,255,255,0.8);

}

/* border input */

.mud-theme-dark .search-input .mud-input-outlined-border{

    border-color:rgba(255,255,255,0.35);

}

/* focus */

.mud-theme-dark .search-input.mud-input-focused .mud-input-outlined-border{

    border-color:#4fc3f7;

    box-shadow:0 0 6px rgba(79,195,247,0.6);

}</style>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-10">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-8">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h2" Style="font-weight: 900; letter-spacing: -1.5px; text-transform: uppercase;" Color="Color.Primary">
                Hệ Thống Người Dùng
            </MudText>
            <MudText Typo="Typo.h6" Class="mud-text-secondary" Style="font-weight: 400;">
                Tổng cộng có <b style="color: var(--mud-palette-primary);">@users.Count</b> tài khoản đang hoạt động
            </MudText>
        </MudStack>
        
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenCreateDialog"
                   Size="Size.Large"
                   Style="height: 60px; font-size: 1.1rem; font-weight: bold; border-radius: 12px; padding: 0 30px;">
            THÊM USER MỚI
        </MudButton>
    </MudStack>

    <MudPaper Elevation="5" Style="border-radius: 20px; padding: 15px; border: 1px solid rgba(0,0,0,0.05)">
        <MudDataGrid Items="@users" 
                    Filterable="true" 
                    Bordered="false" 
                    Striped="true" 
                    Hover="true"
                    QuickFilter="@_quickFilter"
                    T="UserDto">
            <ToolBarContent>
                <MudText Typo="Typo.h5" Style="font-weight: 700;">Danh Sách Chi Tiết</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_searchString"
                            Placeholder="Nhập tên hoặc tài khoản cần tìm..."
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Filled.Search"
                            Variant="Variant.Outlined"
                            Class="search-input"
                            Style="max-width:400px;">
                </MudTextField>
            </ToolBarContent>

            <Columns>
                <PropertyColumn Property="x => x.Id" Title="MÃ ID" Sortable="true" HeaderStyle="font-weight: 800; font-size: 1rem;" />
                
                <TemplateColumn Title="HỌ TÊN & TÀI KHOẢN" HeaderStyle="font-weight: 800; font-size: 1rem;">
                    <CellTemplate>
                        <div class="d-flex align-center py-2">
                            <MudAvatar Color="@GetRoleColor(context.Item.Role)" Variant="Variant.Filled" Size="Size.Medium" Class="mr-4" Style="height: 45px; width: 45px; font-size: 1.2rem;">
                                @context.Item.FullName[0]
                            </MudAvatar>
                            <div class="d-flex flex-column">
                                <MudText Typo="Typo.body1" Style="font-weight: 700; font-size: 1.1rem;">@context.Item.FullName</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@context.Item.Username</MudText>
                            </div>
                        </div>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="PHÂN QUYỀN" HeaderStyle="font-weight: 800; font-size: 1rem;">
                    <CellTemplate>
                        <MudChip T="string" 
                                Color="@GetRoleColor(context.Item.Role)" 
                                Variant="Variant.Filled" 
                                Size="Size.Medium"
                                Style="font-weight: bold; min-width: 100px; justify-content: center;">
                            @context.Item.Role.ToString().ToUpper()
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="TRẠNG THÁI" HeaderStyle="font-weight: 800; font-size: 1rem;">
                    <CellTemplate>
                        @if (context.Item.IsLocked)
                        {
                            <MudText Color="Color.Error" Style="font-weight: 700; display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-1"/> ĐÃ KHÓA
                            </MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Success" Style="font-weight: 700; display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1"/> HOẠT ĐỘNG
                            </MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="THAO TÁC" HeaderStyle="font-weight: 800; font-size: 1rem;" CellClass="d-flex justify-end align-center">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                       Color="Color.Info" 
                                       Size="Size.Medium"
                                       OnClick="@(() => OpenEditDialog(context.Item))" 
                                       Class="mr-2"
                                       Style="background-color: var(--mud-palette-info-hover)"/>

                        <MudIconButton
                            Icon="@(context.Item.IsLocked ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.Lock)"
                            Color="@(context.Item.IsLocked ? Color.Success : Color.Error)"
                            Size="Size.Medium"
                            OnClick="@(() => ToggleLockUser(context.Item))" 
                            Disabled="@(context.Item.Id == currentUserId)"
                            Style="@($"background-color: {(context.Item.IsLocked ? "rgba(76, 175, 80, 0.1)" : "rgba(244, 67, 54, 0.1)")}")" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <PagerContent>
                <div class="pa-4">
                    <MudDataGridPager T="UserDto" />
                </div>
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
</MudContainer>

@code {
    // PHẦN CODE LOGIC GIỮ NGUYÊN HOÀN TOÀN NHƯ CŨ
    private List<UserDto> users = new();
    private string _searchString = string.Empty;
    private int currentUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            currentUserId = await LocalStorage.GetItemAsync<int>("userId");
        }
        catch { }
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            users = await Http.GetFromJsonAsync<List<UserDto>>("api/users") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải dữ liệu: " + ex.Message, Severity.Error);
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserDialog>("Tạo User Mới", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is CreateUpdateUserDto dto)
        {
            var response = await Http.PostAsJsonAsync("api/users", dto);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Tạo thành công!", Severity.Success);
                await LoadData();
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Tạo thất bại: {err}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(UserDto user)
    {
        var updateDto = new CreateUpdateUserDto
        {
            Username = user.Username,
            FullName = user.FullName,
            Email = user.Email,
            Role = user.Role,
            Password = string.Empty
        };

        var parameters = new DialogParameters<UserDialog>
        {
            { x => x.Model, updateDto },
            { x => x.IsEditInfo, true }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserDialog>($"Sửa User: {user.Username}", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is CreateUpdateUserDto dto)
        {
            var response = await Http.PutAsJsonAsync($"api/users/{user.Id}", dto);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Cập nhật thành công!", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Lỗi cập nhật.", Severity.Error);
            }
        }
    }

    private async Task ToggleLockUser(UserDto user)
    {
        if (user.Id == currentUserId)
        {
            Snackbar.Add("Bạn không thể tự khóa tài khoản của chính mình!", Severity.Warning);
            return;
        }

        string action = user.IsLocked ? "MỞ KHÓA" : "KHÓA";
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận",
            $"Bạn có chắc muốn {action} tài khoản '{user.Username}' không?",
            yesText: action, cancelText: "Hủy");

        if (confirm == true)
        {
            var response = await Http.PutAsync($"api/users/{user.Id}/lock", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Đã {action.ToLower()} thành công.", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Thao tác thất bại.", Severity.Error);
            }
        }
    }

    private Color GetRoleColor(UserRole role) => role switch
    {
        UserRole.Admin => Color.Error,
        UserRole.BoothOwner => Color.Warning,
        _ => Color.Info
    };

    private Func<UserDto, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if (x.Username.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (x.FullName.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    };
}