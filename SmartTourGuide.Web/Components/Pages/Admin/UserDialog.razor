@using SmartTourGuide.Shared.DTOs
@using SmartTourGuide.Shared.Enums
@using MudBlazor

<MudDialog Class="user-dialog" Style="border-radius:16px; padding:12px;">    
    <TitleContent>
        <MudText Typo="Typo.h5"
         Style="font-weight:900;
                letter-spacing:1px;
                color:var(--mud-palette-primary);
                text-transform:uppercase;">        
                @(IsEditInfo ? "Sửa thông tin" : "Thêm User Mới")
        </MudText>
    </TitleContent>

    <DialogContent >
        <MudForm @ref="form" @bind-IsValid="@success" Class="py-4 user-form">
            
            <MudTextField @bind-Value="Model.Username" 
                          Label="Tên đăng nhập *" 
                          Required="true" 
                          RequiredError="Bắt buộc"
                          ReadOnly="@IsEditInfo"
                          Variant="@(IsEditInfo ? Variant.Filled : Variant.Outlined)"
                          Class="perfect-input mb-4" />

            @if (!IsEditInfo)
            {
                <MudTextField @bind-Value="Model.Password" 
                              Label="Mật khẩu *" 
                              InputType="InputType.Password"
                              Required="true" 
                              RequiredError="Bắt buộc"
                              Variant="Variant.Outlined"
                              Class="perfect-input mb-4" />
            }

            <MudTextField @bind-Value="Model.FullName" 
                          Label="Họ tên *" 
                          Required="true" 
                          RequiredError="Bắt buộc"
                          Variant="Variant.Outlined"
                          Class="perfect-input mb-4" />
            
            <MudTextField @bind-Value="Model.Email" 
                          Label="Email" 
                          Variant="Variant.Outlined"
                          Class="perfect-input mb-4" />

            <MudSelect T="UserRole" 
                       Label="Vai trò *" 
                       @bind-Value="Model.Role" 
                       AnchorOrigin="Origin.BottomCenter"
                       Variant="Variant.Outlined"
                       Class="perfect-input mb-4">
                <MudSelectItem Value="UserRole.Tourist">Khách du lịch</MudSelectItem>
                <MudSelectItem Value="UserRole.BoothOwner">Chủ gian hàng</MudSelectItem>
                <MudSelectItem Value="UserRole.Admin">Admin</MudSelectItem>
            </MudSelect>

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" 
                   Color="Color.Error"
                   Size="Size.Large"
                   Style="font-size: 1.1rem; font-weight: 700; margin-right: 12px;">
            HỦY
        </MudButton>
        <MudButton Color="Color.Success" 
                   Variant="Variant.Filled" 
                   OnClick="Submit" 
                   Disabled="@(!success)"
                   Size="Size.Large"
                   Style="font-size: 1.1rem; font-weight: 800; padding: 10px 36px; border-radius: 8px;">
            LƯU
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
/* ===== Font tổng cho dialog ===== */
.user-dialog{
    font-family: "Inter", "Segoe UI", Roboto, Arial, sans-serif;
}

/* ===== Title ===== */
.user-dialog h5{
    font-weight:900;
    letter-spacing:1.5px;
}

/* ===== INPUT TEXT ===== */
.perfect-input input{
    font-size:16px;
    font-weight:600;
}

/* ===== LABEL ===== */
.perfect-input .mud-input-label{
    font-weight:700;
    font-size:14px;

    /* sửa lỗi bị viền che */
    background: var(--mud-palette-background);
    padding: 0 6px;

    z-index: 2;
}

/* ===== LABEL khi focus ===== */
.perfect-input.mud-input-focused .mud-input-label{
    color: var(--mud-palette-primary);
}


/* ===== BORDER INPUT ===== */
.perfect-input .mud-input-outlined-border{
    border-width:2px;
}
/* ===== HOVER ===== */
.perfect-input:hover .mud-input-outlined-border{
    border-color: var(--mud-palette-primary);
}

/* ===== Select text ===== */
.perfect-input .mud-select-input{
    font-size:16px;
    font-weight:600;
}

/* ===== Placeholder ===== */
.perfect-input input::placeholder{
    font-weight:500;
}

/* ===== DARK MODE ===== */
.mud-theme-dark .perfect-input input{
    color:#ffffff !important;
}

.mud-theme-dark .perfect-input .mud-input-label{
    color:#e0e0e0;
}

.mud-theme-dark .perfect-input .mud-select-input{
    color:#ffffff;
}

.mud-theme-dark .perfect-input input::placeholder{
    color:#bdbdbd;
}

/* ===== Text rendering sắc nét ===== */
body{
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
}
</style>




@code {
    [CascadingParameter] IMudDialogInstance MudDialogRef { get; set; } = default!;

    [Parameter]
    public CreateUpdateUserDto Model { get; set; } = new CreateUpdateUserDto()
    {
        Username = "",
        Password = "",
        FullName = "",
        Email
= ""
    };
    [Parameter] public bool IsEditInfo { get; set; } = false; // True = Sửa, False = Tạo mới

    MudForm? form;
    bool success;

    void Submit() => MudDialogRef.Close(DialogResult.Ok(Model));
    void Cancel() => MudDialogRef.Cancel();
}