@inherits LayoutComponentBase
@inject NavigationManager Nav
@using SmartTourGuide.Web.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h5">
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home">Smart Tour Guide System
            </MudNavLink>
        </MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Class="mr-4">Xin chào, @(context.User.Identity?.Name ?? "Khách")</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Logout">Đăng xuất</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Filled" Color="Color.Success" Href="/login">Đăng nhập</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer Open="true" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <!-- Menu cho Admin -->
            <AuthorizeView Roles="Admin">
                <MudNavLink Href="/admin/approvals" Icon="@Icons.Material.Filled.CheckCircle">Duyệt bài đăng
                </MudNavLink>
                <MudNavLink Href="/admin/tracking" Icon="@Icons.Material.Filled.Map">Bản đồ theo dõi</MudNavLink>
            </AuthorizeView>

            <!-- Menu cho Chủ gian hàng (BoothOwner) -->
            <AuthorizeView Roles="BoothOwner">
                <MudNavLink Href="/owner/create-poi" Icon="@Icons.Material.Filled.AddLocation">Tạo địa điểm</MudNavLink>
                <MudNavLink Href="/owner/my-pois" Icon="@Icons.Material.Filled.List">Địa điểm của tôi</MudNavLink>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private async Task Logout()
    {
        // Đảm bảo bạn đã await lệnh clear
        await LocalStorage.ClearAsync();

        // Thêm await vào trước lệnh Notify
        await ((CustomAuthStateProvider)AuthStateProvider).NotifyUserLogout();

        Nav.NavigateTo("/login", forceLoad: true);
    }
}