@inherits LayoutComponentBase
@inject NavigationManager Nav
@using SmartTourGuide.Web.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject HttpClient Http

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="@_customTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    

    <MudAppBar Elevation="0" Color="Color.Surface" Dense="true" Class="px-4 py-2" Style="min-height: 64px;"> 

        @if (!IsLoginPage) 
        {
            <MudIconButton Icon="@Icons.Material.Filled.Menu" 
                           OnClick="@ToggleDrawer" 
                           Class="me-3" 
                           Style="@($"background: {(_isDarkMode ? "rgba(255,255,255,0.1)" : "rgba(0,0,0,0.08)")}; border-radius: 8px; width: 42px; height: 42px;")" />
        }

        <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: 0.5px; color: var(--mud-palette-text-primary);">
            QUẢN LÝ GIAN HÀNG & ĐỊA ĐIỂM
        </MudText>

        <MudSpacer />

        <AuthorizeView>
            <Authorized Context="authContext">
                <div class="d-flex align-center gap-2">
                    
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                                   Color="@(_isDarkMode ? Color.Warning : Color.Default)"
                                   OnClick="@DarkModeToggle"
                                   Style="@($"background: {(_isDarkMode ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.03)")}; border-radius: 50%;")" />

                    <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone" 
                                   Color="Color.Default" 
                                   Style="@($"background: {(_isDarkMode ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.03)")}; border-radius: 50%;")" />

                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" PopoverClass="rounded-xl mt-3" ListClass="pa-0">
                        <ActivatorContent>
                            <div class="user-pill d-flex align-center gap-2 cursor-pointer">
                                <div style="width:32px; height:32px; border-radius:50%; overflow:hidden; border:2px solid var(--mud-palette-surface);">
                                    <img src="@_adminAvatarUrl" alt="Avatar" style="width:100%; height:100%; object-fit:cover;" />
                                </div>
                                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@authContext.User.Identity?.Name</MudText>
                                </MudHidden>
                                <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
                            </div>
                        </ActivatorContent>
                        <ChildContent>
                            <div style="width: 250px;">
                                <div class="pa-4">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight: 800;">@GetGreeting(), @authContext.User.Identity?.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Quản lý tài khoản</MudText>
                                </div>
                                <MudDivider />
                                <MudListItem T="string" Icon="@Icons.Material.Outlined.Person" >
                                    Hồ sơ của tôi
                                </MudListItem>
                                <MudDivider />
                                <MudListItem T="string" Icon="@Icons.Material.Outlined.Logout" IconColor="Color.Error" OnClick="Logout">
                                    Đăng xuất
                                </MudListItem>
                            </div>
                        </ChildContent>
                    </MudMenu>

                </div>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always" Class="argon-drawer" Width="280px">
        <div class="sidebar-content">
            
            <div class="brand-section">
                <MudIcon Icon="@Icons.Material.Filled.Storefront" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.h6" Class="brand-text">BOOTH MANAGER</MudText>
            </div>

            <MudNavMenu>
                <AuthorizeView Roles="Admin">
                    <MudText Typo="Typo.caption" Class="menu-group-title">QUẢN LÝ ADMIN</MudText>
                    <MudNavLink Href="/admin/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Tổng quan</MudNavLink>
                    <MudNavLink Href="/admin/approvals" Icon="@Icons.Material.Filled.CheckCircle">Duyệt bài đăng</MudNavLink>
                    <MudNavLink Href="/admin/tours" Icon="@Icons.Material.Filled.Map">Quản lý Tour</MudNavLink>
                    <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">Quản lý User</MudNavLink>
                </AuthorizeView>

                <AuthorizeView Roles="BoothOwner">
                    <MudText Typo="Typo.caption" Class="menu-group-title mt-4">CHỦ GIAN HÀNG</MudText>
                    <MudNavLink Href="/owner/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Tổng quan</MudNavLink>
                    <MudNavLink Href="/owner/analytics" Icon="@Icons.Material.Filled.Analytics">Thống kê POI</MudNavLink>
                    <MudNavLink Href="/owner/create-poi" Icon="@Icons.Material.Filled.AddLocation">Tạo địa điểm</MudNavLink>
                    <MudNavLink Href="/owner/my-pois" Icon="@Icons.Material.Filled.List">Địa điểm của tôi</MudNavLink>
                    <MudNavLink Href="/tts-studio" Icon="@Icons.Material.Filled.RecordVoiceOver"
                                Style="color: var(--mud-palette-secondary);">
                        🎙️ TTS Studio
                    </MudNavLink>
                </AuthorizeView>
            </MudNavMenu>
        </div>
    </MudDrawer>

    <MudMainContent Style="background: var(--mud-palette-background); min-height: 100vh;">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;
    string _adminAvatarUrl = "";
    bool _isDarkMode = false;

    MudTheme _customTheme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#fb6340",       
            Surface = "#0d1117",       
            Background = "#010409",    
            AppbarBackground = "#010409", 
            DrawerBackground = "#010409", 
            TextPrimary = "#f0f6fc",   
            TextSecondary = "#8b949e", 
            Divider = "rgba(255,255,255,0.05)", 
            ActionDefault = "#8b949e"
        },
        PaletteLight = new PaletteLight()
        {
            Primary = "#fb6340",
            Background = "#f5f7fa",
            Surface = "#ffffff",
            DrawerBackground = "#f5f7fa"
        }
    };

    protected override void OnInitialized()
    {
        _adminAvatarUrl = Nav.BaseUri + "img/icon.jpg"; 
    }

    void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private bool IsLoginPage => Nav.Uri.EndsWith("/") || Nav.Uri.Contains("/login");

    private async Task Logout()
    {
        await LocalStorage.ClearAsync();
        await ((CustomAuthStateProvider)AuthStateProvider).NotifyUserLogout();
        Nav.NavigateTo("/", true);
    }
    
    private string GetGreeting()
    {
        int hour = DateTime.Now.Hour;
        if (hour >= 0 && hour < 12) return "Chào buổi sáng";
        else if (hour >= 12 && hour < 18) return "Chào buổi chiều";
        else return "Chào buổi tối";
    }

    // ✅ Set X-User-Name header mỗi khi layout load (kể cả sau F5)
    private bool _headerSet = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _headerSet) return;
        _headerSet = true;
        try
        {
            var username = await LocalStorage.GetItemAsync<string>("username");
            if (!string.IsNullOrEmpty(username))
            {
                Http.DefaultRequestHeaders.Remove("X-User-Name");
                Http.DefaultRequestHeaders.Add("X-User-Name", username);
            }
        }
        catch { }
    }
}