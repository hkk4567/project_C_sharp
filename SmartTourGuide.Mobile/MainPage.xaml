<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:res="clr-namespace:SmartTourGuide.Mobile.Resources.Strings"
             x:Class="SmartTourGuide.Mobile.MainPage"
             Title="{x:Static res:AppResources.MapTitle}">

    <Grid>
        <Border x:Name="OfflineBanner"
                IsVisible="False"
                Opacity="0"
                BackgroundColor="#E65100"
                ZIndex="999"
                VerticalOptions="Start"
                HorizontalOptions="Fill"
                Padding="12,8"
                Margin="0"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,3"
                        Radius="6"
                        Opacity="0.25"/>
            </Border.Shadow>

            <HorizontalStackLayout Spacing="10"
                                   HorizontalOptions="Center">

                <!-- Icon wifi off -->
                <Label Text="📴"
                       FontSize="16"
                       VerticalOptions="Center"/>

                <!-- Nội dung thông báo (cập nhật bằng code) -->
                <Label x:Name="OfflineBannerLabel"
                       Text="{x:Static res:AppResources.StatusBannerOffline}"
                       TextColor="White"
                       FontSize="13"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>

            </HorizontalStackLayout>
        </Border>
        <!-- ══ BẢN ĐỒ FULL SCREEN ══════════════════════════════════════════ -->
        <mapsui:MapView x:Name="mapView"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill"
                        IsMyLocationButtonVisible="False"/>

        <!-- ══ TOP BAR — chỉ còn nút ngôn ngữ góc trên trái ═════════════════ -->
        <Border BackgroundColor="White"
                StrokeThickness="0"
                HeightRequest="40"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,16,0,0"
                Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,2"
                        Radius="8"
                        Opacity="0.12"/>
            </Border.Shadow>
            <Button x:Name="btnLanguage"
                    Clicked="OnChangeLanguageClicked"
                    FontAttributes="Bold"
                    FontSize="13"
                    HeightRequest="40"
                    CornerRadius="20"
                    BackgroundColor="Transparent"
                    TextColor="#212121"
                    Padding="14,0"/>
        </Border>

        <!-- ══ STATUS PILL — nhỏ gọn, không che map ════════════════════════ -->
        <Border BackgroundColor="#F2000000"
                StrokeThickness="0"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,68,0,0"
                Padding="12,6">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Label x:Name="statusLabel"
                   Text="Đang tải..."
                   TextColor="White"
                   FontSize="12"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>
        </Border>

        <!-- ══ FAB GROUP — góc phải, dưới thanh zoom của Mapsui ════════════ -->
        <VerticalStackLayout HorizontalOptions="End"
                             VerticalOptions="Start"
                             Margin="0,160,16,0"
                             Spacing="8">

            <!-- Nút Reload -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    HeightRequest="48"
                    WidthRequest="48"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,3"
                            Radius="10"
                            Opacity="0.15"/>
                </Border.Shadow>
                <Button Text="↺"
                        Clicked="OnReloadClicked"
                        FontSize="20"
                        HeightRequest="48"
                        WidthRequest="48"
                        CornerRadius="24"
                        BackgroundColor="Transparent"
                        TextColor="#1565C0"
                        Padding="0"/>
            </Border>

            <!-- Nút về vị trí hiện tại -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    HeightRequest="48"
                    WidthRequest="48"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,3"
                            Radius="10"
                            Opacity="0.15"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCenterMyLocationClicked"/>
                </Border.GestureRecognizers>
                <Label Text="🎯"
                       FontSize="22"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

        </VerticalStackLayout>

        <!-- ══ NÚT CHỌN TOUR — FAB chính ════════════════════════════════════ -->
        <Button x:Name="btnShowTours"
                Text="{x:Static res:AppResources.BtnSelectTour}"
                Clicked="OnShowToursClicked"
                FontAttributes="Bold"
                FontSize="15"
                HeightRequest="52"
                CornerRadius="26"
                BackgroundColor="#F57C00"
                TextColor="White"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,44"
                Padding="28,0">
            <Button.Shadow>
                <Shadow Brush="#F57C00"
                        Offset="0,6"
                        Radius="16"
                        Opacity="0.4"/>
            </Button.Shadow>
        </Button>

        <!-- ══ TOUR INFO PANEL — strip ngang thu gọn ════════════════════════ -->
        <!--
            Thiết kế mới: card nhỏ gọn ở góc dưới-trái, không che toàn màn hình.
            Danh sách POI cuộn ngang (horizontal scroll).
        -->
        <Border x:Name="TourInfoPanel"
                IsVisible="False"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16,16,16,16"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="12,0,12,108"
                Padding="0">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,-4"
                        Radius="20"
                        Opacity="0.13"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="*">

                <!-- Header compact -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*,Auto"
                      Padding="14,10,6,10">

                    <!-- Icon + tên tour -->
                    <Label Grid.Column="0"
                           Text="🗺️"
                           FontSize="16"
                           VerticalOptions="Center"
                           Margin="0,0,8,0"/>
                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="1"
                                         VerticalOptions="Center">
                        <Label Text="{x:Static res:AppResources.ItineraryTitle}"
                               FontSize="10"
                               TextColor="#F57C00"
                               FontAttributes="Bold"
                               CharacterSpacing="1"/>
                        <Label x:Name="lblTourName"
                               Text=""
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                    </VerticalStackLayout>

                    <!-- Nút đóng -->
                    <Button Grid.Column="2"
                            Text="✕"
                            FontSize="14"
                            TextColor="#9E9E9E"
                            BackgroundColor="Transparent"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            Clicked="OnCloseTourPanelClicked"/>
                </Grid>

                <!-- Danh sách POI cuộn NGANG -->
                <ScrollView Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            Margin="0,0,0,12">
                    <HorizontalStackLayout x:Name="tourPoiList"
                                           Padding="12,0,12,0"
                                           Spacing="0"/>
                </ScrollView>

            </Grid>
        </Border>

        <!-- ══ POPUP CHI TIẾT POI — bottom sheet nhỏ gọn ══════════════════ -->
        <!--
            Thiết kế mới:
            • Ảnh thu nhỏ + info xếp ngang (image bên trái, text bên phải)
            • Không che hết map, chỉ chiếm ~220px từ dưới lên
            • Drag handle ở trên cùng
        -->
        <Border x:Name="DetailPopup"
                IsVisible="False"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20,20,0,0"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="0"
                Padding="0">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,-6"
                        Radius="24"
                        Opacity="0.14"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto">

                <!-- Drag handle -->
                <Grid Grid.Row="0"
                      Padding="0,10,0,4">
                    <BoxView WidthRequest="36"
                             HeightRequest="4"
                             CornerRadius="2"
                             Color="#E0E0E0"
                             HorizontalOptions="Center"/>
                    <!-- Nút đóng góc phải -->
                    <Button Text="✕"
                            TextColor="#9E9E9E"
                            BackgroundColor="Transparent"
                            FontSize="15"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            HorizontalOptions="End"
                            Margin="0,0,8,0"
                            Clicked="OnClosePopupClicked"/>
                </Grid>

                <!-- Content: ảnh trái + info phải -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="110,*"
                      Margin="14,0,14,0"
                      ColumnSpacing="14">

                    <!-- Ảnh thumbnail -->
                    <Border Grid.Column="0"
                            x:Name="ImageContainer"
                            HeightRequest="90"
                            WidthRequest="110"
                            StrokeThickness="0"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Image x:Name="imgPoi"
                               Aspect="AspectFill"
                               BackgroundColor="#F5F5F5"/>
                    </Border>

                    <!-- Text info -->
                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="4"
                                         VerticalOptions="Center">
                        <Label x:Name="lblPoiName"
                               Text="Tên địa điểm"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"/>
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0"
                                   Text="📍"
                                   FontSize="12"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   x:Name="lblAddress"
                                   FontSize="12"
                                   TextColor="#757575"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   Margin="4,0,0,0"/>
                        </Grid>
                        <Label x:Name="lblDescription"
                               FontSize="13"
                               TextColor="#555555"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"
                               LineHeight="1.35"
                               Margin="0,2,0,0"/>
                    </VerticalStackLayout>

                </Grid>

                <!-- Nút Audio -->
                <Button Grid.Row="2"
                        x:Name="btnPlayAudio"
                        Text="{x:Static res:AppResources.BtnListen}"
                        BackgroundColor="#1976D2"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        HeightRequest="48"
                        CornerRadius="14"
                        Margin="14,12,14,24"
                        Clicked="OnPlayAudioClicked">
                    <Button.Shadow>
                        <Shadow Brush="#1976D2"
                                Offset="0,4"
                                Radius="12"
                                Opacity="0.3"/>
                    </Button.Shadow>
                    <!-- Bo góc riêng vì CornerRadius trên Button MAUI đôi khi cần override -->
                    <Button.Triggers>
                        <Trigger TargetType="Button"
                                 Property="IsEnabled"
                                 Value="True">
                            <!-- styling handled via CornerRadius below -->
                        </Trigger>
                    </Button.Triggers>
                </Button>

            </Grid>
        </Border>

    </Grid>

</ContentPage>
