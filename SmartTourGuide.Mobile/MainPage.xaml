<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:res="clr-namespace:SmartTourGuide.Mobile.Resources.Strings"
             x:Class="SmartTourGuide.Mobile.MainPage"
             Title="{x:Static res:AppResources.MapTitle}">

    <Grid BackgroundColor="#EEF3F8">
        <Border x:Name="OfflineBanner"
                IsVisible="False"
                Opacity="0"
                BackgroundColor="#E07A2F"
                ZIndex="999"
                VerticalOptions="Start"
                HorizontalOptions="Fill"
                Padding="12,8"
                Margin="0"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,3"
                        Radius="6"
                        Opacity="0.25"/>
            </Border.Shadow>

            <HorizontalStackLayout Spacing="10"
                                   HorizontalOptions="Center">

                <!-- Icon wifi off -->
                <Label Text="📴"
                       FontSize="16"
                       VerticalOptions="Center"/>

                <!-- Nội dung thông báo (cập nhật bằng code) -->
                <Label x:Name="OfflineBannerLabel"
                       Text="{x:Static res:AppResources.StatusBannerOffline}"
                       TextColor="White"
                       FontSize="13"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>

            </HorizontalStackLayout>
        </Border>
        <!-- ══ BẢN ĐỒ FULL SCREEN ══════════════════════════════════════════ -->
        <mapsui:MapView x:Name="mapView"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill"
                        ButtonMargin="0,220,16,0"
                        IsMyLocationButtonVisible="False"/>

        <!-- ══ SEARCH + LANGUAGE BAR ═══════════════════════════════════════ -->
        <Border BackgroundColor="#FDFEFF"
                StrokeThickness="1"
                Stroke="#E4EAF2"
                HorizontalOptions="Fill"
                VerticalOptions="Start"
                Margin="12,12,12,0"
                Padding="14"
                ZIndex="998">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,8"
                        Radius="18"
                        Opacity="0.12"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <Grid ColumnDefinitions="Auto,*"
                          BackgroundColor="#F6F8FB"
                          HeightRequest="44"
                          Padding="14,0"
                          ColumnSpacing="10">
                        <Label Text="🔎"
                               FontSize="16"
                               VerticalOptions="Center"
                               TextColor="#F57C00"/>
                        <Entry x:Name="poiSearchBar"
                               Grid.Column="1"
                               Placeholder="Tìm quán, địa điểm..."
                               TextChanged="OnPoiSearchTextChanged"
                               Completed="OnPoiSearchSubmitted"
                               BackgroundColor="Transparent"
                               TextColor="#1A1A1A"
                               PlaceholderColor="#757575"
                               ReturnType="Search"
                               VerticalOptions="Center"/>
                    </Grid>

                    <Border Grid.Column="1"
                            BackgroundColor="#F6F8FB"
                            StrokeThickness="1"
                            Stroke="#E4EAF2"
                            HeightRequest="44"
                            WidthRequest="128"
                            Padding="0"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>
                        <Button x:Name="btnLanguage"
                                Clicked="OnChangeLanguageClicked"
                                FontAttributes="Bold"
                                FontSize="12"
                                HeightRequest="44"
                                CornerRadius="22"
                                BackgroundColor="Transparent"
                                TextColor="#212121"
                                Padding="10,0"/>
                    </Border>
                </Grid>

                <Border x:Name="SearchSuggestionsPanel"
                        Grid.Row="1"
                        IsVisible="False"
                        BackgroundColor="#FFFFFF"
                        StrokeThickness="1"
                        Stroke="#E4EAF2"
                        Padding="0"
                        MaximumHeightRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,6"
                                Radius="16"
                                Opacity="0.10"/>
                    </Border.Shadow>

                    <CollectionView x:Name="poiSearchSuggestions"
                                    SelectionMode="Single"
                                    SelectionChanged="OnPoiSearchSelectionChanged"
                                    BackgroundColor="Transparent"
                                    Margin="0"
                                    ItemSizingStrategy="MeasureAllItems">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="Transparent"
                                        StrokeThickness="0"
                                        Padding="14,12">
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <Label Text="📍"
                                               FontSize="18"
                                               VerticalOptions="Center"/>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2">
                                            <Label Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="#1A1A1A"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Text="{Binding Address}"
                                                   FontSize="12"
                                                   TextColor="#757575"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </Grid>
        </Border>

        <!-- ══ STATUS PILL — nhỏ gọn, không che map ════════════════════════ -->
        <Border BackgroundColor="#F2000000"
                StrokeThickness="1"
                Stroke="#202531"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,132,0,0"
                Padding="14,7">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="999"/>
            </Border.StrokeShape>
            <Label x:Name="statusLabel"
                   Text="Đang tải..."
                   TextColor="White"
                   FontSize="12"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>
        </Border>

        <!-- ══ FAB GROUP — góc phải, dưới thanh zoom của Mapsui ════════════ -->
        <VerticalStackLayout HorizontalOptions="End"
                             VerticalOptions="Start"
                             Margin="0,364,16,0"
                             Spacing="10">

            <!-- Nút Reload -->
            <Border BackgroundColor="#FFFFFFF4"
                    StrokeThickness="1"
                    Stroke="#E4EAF2"
                    HeightRequest="48"
                    WidthRequest="48"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,6"
                            Radius="14"
                            Opacity="0.12"/>
                </Border.Shadow>
                <Button Text="↺"
                        Clicked="OnReloadClicked"
                        FontSize="20"
                        HeightRequest="48"
                        WidthRequest="48"
                        CornerRadius="24"
                        BackgroundColor="Transparent"
                        TextColor="#1F5FBF"
                        Padding="0"/>
            </Border>

            <!-- Nút về vị trí hiện tại -->
            <Border BackgroundColor="#FFFFFFF4"
                    StrokeThickness="1"
                    Stroke="#E4EAF2"
                    HeightRequest="48"
                    WidthRequest="48"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,6"
                            Radius="14"
                            Opacity="0.12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCenterMyLocationClicked"/>
                </Border.GestureRecognizers>
                <Label Text="🎯"
                       FontSize="22"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

        </VerticalStackLayout>

        <!-- ══ NÚT CHỌN TOUR — FAB chính ════════════════════════════════════ -->
        <Button x:Name="btnShowTours"
                Text="{x:Static res:AppResources.BtnSelectTour}"
                Clicked="OnShowToursClicked"
                FontAttributes="Bold"
                FontSize="15"
                HeightRequest="52"
                CornerRadius="26"
                BackgroundColor="#F57C00"
                BorderColor="#FFB15B"
                BorderWidth="1"
                TextColor="White"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,44"
                Padding="28,0">
            <Button.Shadow>
                <Shadow Brush="#F57C00"
                        Offset="0,8"
                        Radius="18"
                        Opacity="0.36"/>
            </Button.Shadow>
        </Button>

        <!-- ══ TOUR INFO PANEL — strip ngang thu gọn ════════════════════════ -->
        <!--
            Thiết kế mới: card nhỏ gọn ở góc dưới-trái, không che toàn màn hình.
            Danh sách POI cuộn ngang (horizontal scroll).
        -->
        <Border x:Name="TourInfoPanel"
                IsVisible="False"
                BackgroundColor="#FFFFFFF7"
                StrokeThickness="1"
                Stroke="#E4EAF2"
                StrokeShape="RoundRectangle 18,18,18,18"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="12,0,12,108"
                Padding="0">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,-6"
                        Radius="22"
                        Opacity="0.10"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="*">

                <!-- Header compact -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*,Auto"
                      Padding="16,12,8,10">

                    <!-- Icon + tên tour -->
                    <Label Grid.Column="0"
                           Text="🗺️"
                           FontSize="16"
                           VerticalOptions="Center"
                           Margin="0,0,8,0"/>
                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="1"
                                         VerticalOptions="Center">
                        <Label Text="{x:Static res:AppResources.ItineraryTitle}"
                               FontSize="10"
                               TextColor="#F57C00"
                               FontAttributes="Bold"
                               CharacterSpacing="1.4"/>
                        <Label x:Name="lblTourName"
                               Text=""
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                    </VerticalStackLayout>

                    <!-- Nút đóng -->
                    <Button Grid.Column="2"
                            Text="✕"
                            FontSize="14"
                            TextColor="#9E9E9E"
                            BackgroundColor="Transparent"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            Clicked="OnCloseTourPanelClicked"/>
                </Grid>

                <!-- Danh sách POI cuộn NGANG -->
                <ScrollView Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            Margin="0,0,0,12">
                    <HorizontalStackLayout x:Name="tourPoiList"
                                           Padding="12,0,12,0"
                                           Spacing="0"/>
                </ScrollView>

            </Grid>
        </Border>

        <!-- ══ POPUP CHI TIẾT POI — bottom sheet nhỏ gọn ══════════════════ -->
        <!--
            Thiết kế mới:
            • Ảnh thu nhỏ + info xếp ngang (image bên trái, text bên phải)
            • Không che hết map, chỉ chiếm ~220px từ dưới lên
            • Drag handle ở trên cùng
        -->
        <Border x:Name="DetailPopup"
                IsVisible="False"
                BackgroundColor="#FFFFFFFD"
                StrokeThickness="1"
                Stroke="#DCE4EE"
                StrokeShape="RoundRectangle 24,24,0,0"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="0"
                Padding="0"
                ZIndex="995">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="0,-10"
                        Radius="28"
                        Opacity="0.12"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                <!-- Drag handle + close -->
                <Grid Grid.Row="0"
                      Padding="0,12,0,4">
                    <BoxView WidthRequest="42"
                             HeightRequest="4"
                             CornerRadius="2"
                             Color="#DADFE8"
                             HorizontalOptions="Center"/>
                    <Button Text="✕"
                            TextColor="#9E9E9E"
                            BackgroundColor="Transparent"
                            FontSize="16"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            HorizontalOptions="End"
                            Margin="0,0,8,0"
                            Clicked="OnClosePopupClicked"/>
                </Grid>

                <!-- Header -->
                <VerticalStackLayout Grid.Row="1"
                                     Spacing="4"
                                     Padding="20,0,20,12">
                    <Label x:Name="lblPoiDetailTitle"
                           Text=""
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="1.2"
                           TextColor="#F57C00"/>
                    <Label x:Name="lblPoiName"
                           Text="Tên địa điểm"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#102A43"
                           MaxLines="2"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>

                <!-- Content: ảnh trái + info phải -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="112,*"
                      Margin="18,0,18,0"
                      ColumnSpacing="14">

                    <Border Grid.Column="0"
                            x:Name="ImageContainer"
                            HeightRequest="102"
                            WidthRequest="112"
                            StrokeThickness="0"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Image x:Name="imgPoi"
                               Aspect="AspectFill"
                               BackgroundColor="#EEF3F8"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="8"
                                         VerticalOptions="Center">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="📍"
                                   FontSize="13"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   x:Name="lblAddress"
                                   FontSize="13"
                                   TextColor="#425466"
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"/>
                        </Grid>

                        <Border BackgroundColor="#F6F8FB"
                                StrokeThickness="1"
                                Stroke="#E4EAF2"
                                Padding="12,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="lblDescriptionHeader"
                                       Text=""
                                       FontSize="10"
                                       TextColor="#F57C00"
                                       FontAttributes="Bold"
                                       CharacterSpacing="1"/>
                                <Label x:Name="lblDescription"
                                       FontSize="13"
                                       TextColor="#1F2937"
                                       LineBreakMode="WordWrap"
                                       MaxLines="4"
                                       LineHeight="1.35"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                </Grid>

                <!-- Nút Audio -->
                <Button Grid.Row="3"
                        x:Name="btnPlayAudio"
                        Text="{x:Static res:AppResources.BtnListen}"
                        BackgroundColor="#F57C00"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        HeightRequest="50"
                        CornerRadius="16"
                        Margin="18,16,18,24"
                        Clicked="OnPlayAudioClicked">
                    <Button.Shadow>
                        <Shadow Brush="#F57C00"
                                Offset="0,6"
                                Radius="16"
                                Opacity="0.34"/>
                    </Button.Shadow>
                </Button>

            </Grid>
        </Border>

    </Grid>

</ContentPage>
