<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:res="clr-namespace:SmartTourGuide.Mobile.Resources.Strings" 
             x:Class="SmartTourGuide.Mobile.MainPage"
             Title="{x:Static res:AppResources.MapTitle}">

    <Grid>
		<mapsui:MapView x:Name="mapView"
                VerticalOptions="Fill"
                HorizontalOptions="Fill"
			    IsMyLocationButtonVisible="True" />

        <!-- Nút tải lại dữ liệu (góc trên) -->
        <Button Text="{x:Static res:AppResources.BtnReload}" 
                Clicked="OnReloadClicked"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,20,0,0"
                BackgroundColor="Blue"
                TextColor="White"/>

        <!-- Thanh trạng thái (góc dưới) -->
        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 10,10,10,10"
                Margin="20"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Padding="10">
            <Label x:Name="statusLabel"
                    Text="Đang tải vị trí..."
                   TextColor="Black"
                    HorizontalTextAlignment="Center"/>
        </Border>

        <!-- Nút mở Danh sách Tour (Thêm vào Grid) -->
        <Button Text="{x:Static res:AppResources.BtnSelectTour}"
                Clicked="OnShowToursClicked"
                FontAttributes="Bold"
                HeightRequest="50"
                CornerRadius="25"
                BackgroundColor="#FF9800"
                TextColor="White"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,90">
            <!-- THÊM ĐOẠN NÀY ĐỂ ĐỔ BÓNG -->
            <Button.Shadow>
                <Shadow Brush="Black" Offset="5,5" Radius="5" Opacity="0.3" />
            </Button.Shadow>
        </Button>

        <!-- MỚI: Nút đổi ngôn ngữ (Nằm trên bản đồ) -->
        <Button x:Name="btnLanguage"
                Clicked="OnChangeLanguageClicked"
                FontAttributes="Bold"
                HeightRequest="40"
                CornerRadius="20"
                BackgroundColor="#4CAF50"
                TextColor="White"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="0,20,20,0">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="5,5" Radius="5" Opacity="0.3" />
            </Button.Shadow>
        </Button>
        
        <Border Stroke="#E0E0E0"
                StrokeThickness="1"
                BackgroundColor="White"
                HeightRequest="56"
                WidthRequest="56"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0, 0, 20, 100"
                Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="Black"
                        Offset="0,4"
                        Radius="10"
                        Opacity="0.15" />
                    </Border.Shadow>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCenterMyLocationClicked" />
                    </Border.GestureRecognizers>

                    <Grid>
                        <Label Text="🎯" 
                       FontSize="24"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                    </Grid>

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroupList>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#F5F5F5" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateGroupList>
                    </VisualStateManager.VisualStateGroups>
        </Border>

        <Border x:Name="DetailPopup"
                IsVisible="False" 
                BackgroundColor="White"
                Stroke="Transparent"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0" 
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="0"
                Padding="0" Shadow="{Shadow Brush=Black, Offset='0,-10', Radius=20, Opacity=0.15}">

            <Grid RowDefinitions="Auto, Auto">

                <Grid x:Name="ImageContainer" Grid.Row="0" HeightRequest="200">
                    <Image x:Name="imgPoi" 
                           Aspect="AspectFill"
                           BackgroundColor="#EEEEEE" />

                    <Button Text="✕" 
                            TextColor="#333333" 
                            BackgroundColor="#CCFFFFFF" 
                            FontAttributes="Bold"
                            CornerRadius="18"
                            HeightRequest="36" 
                            WidthRequest="36" 
                            Padding="0"
                            Margin="15"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Clicked="OnClosePopupClicked"
                            Shadow="{Shadow Brush=Black, Offset='0,2', Radius=5, Opacity=0.2}"/>
                </Grid>

                <VerticalStackLayout Grid.Row="1" Padding="20,15,20,30" Spacing="8">

                    <Label x:Name="lblPoiName" 
                           Text="Tên địa điểm" 
                           FontSize="22" 
                           FontAttributes="Bold" 
                           TextColor="#212121"/>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="📍" FontSize="14" VerticalOptions="Center"/>
                        <Label x:Name="lblAddress" 
                               Text="Địa chỉ..." 
                               FontSize="14" 
                               TextColor="#757575" 
                               VerticalOptions="Center"
                               LineBreakMode="TailTruncation"/>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5" />

                    <Label x:Name="lblDescription" 
                           Text="Mô tả chi tiết địa điểm..." 
                           MaxLines="4" 
                           LineBreakMode="TailTruncation" 
                           TextColor="#424242" 
                           FontSize="15" 
                           LineHeight="1.4" />

                    <Button x:Name="btnPlayAudio"
                            Text="{x:Static res:AppResources.BtnListen}" 
                            BackgroundColor="#2196F3" 
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="25" 
                            Margin="0,15,0,0"
                            Clicked="OnPlayAudioClicked"
                            Shadow="{Shadow Brush='#2196F3', Offset='0,4', Radius=10, Opacity=0.3}"/>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>

</ContentPage>