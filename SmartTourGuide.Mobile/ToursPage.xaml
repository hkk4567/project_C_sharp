<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:SmartTourGuide.Mobile.Resources.Strings"
             x:Class="SmartTourGuide.Mobile.ToursPage"
             Title="{x:Static strings:AppResources.ToursPageTitle}">

    <Grid>
        <!-- ── CONTENT CHÍNH ──────────────────────────────────────────── -->
        <Grid RowDefinitions="Auto, *">

            <!-- Header -->
            <HorizontalStackLayout Grid.Row="0" Margin="15" Spacing="10">
                <Button Text="{x:Static strings:AppResources.BtnBack}"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="Black"/>
                <Label Text="{x:Static strings:AppResources.SelectTourHeader}"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Danh sách Tour -->
            <CollectionView x:Name="cvTours"
                            Grid.Row="1"
                            SelectionMode="None"
                            Margin="15,0,15,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,15"
                                Padding="0"
                                Stroke="LightGray"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0, 5" Radius="10" Opacity="0.1"/>
                            </Border.Shadow>

                            <Grid RowDefinitions="150, Auto">

                                <!-- Ảnh bìa -->
                                <Image Grid.Row="0"
                                       Source="{Binding ThumbnailUrl}"
                                       Aspect="AspectFill"
                                       BackgroundColor="#E0E0E0"/>

                                <!-- Thông tin + Nút chọn -->
                                <VerticalStackLayout Grid.Row="1" Padding="15">

                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="Black"/>

                                    <Label Text="{Binding Description}"
                                           FontSize="14"
                                           TextColor="DarkGray"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           Margin="0,5,0,0"/>

                                    <!-- Số POI + nút xem lộ trình -->
                                    <Grid ColumnDefinitions="*, Auto"
                                          Margin="0,10,0,0">

                                        <HorizontalStackLayout Grid.Column="0"
                                                               Spacing="5"
                                                               VerticalOptions="Center">
                                            <Label Text="📍" VerticalOptions="Center"/>
                                            <Label Text="{Binding TotalPois, StringFormat={x:Static strings:AppResources.PoiCountFormat}}"
                                                   TextColor="#2196F3"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <!-- Nút xem chi tiết lộ trình -->
                                        <Button Grid.Column="1"
                                                Text="Xem lộ trình ›"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                BackgroundColor="#FF9800"
                                                TextColor="White"
                                                HeightRequest="36"
                                                CornerRadius="18"
                                                Padding="12,0"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnViewItineraryClicked"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Label Text="{x:Static strings:AppResources.StatusLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Margin="20"/>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <!-- ── OVERLAY CHI TIẾT LỘ TRÌNH ─────────────────────────────── -->
        <!-- Dim nền khi overlay hiện -->
        <BoxView x:Name="dimOverlay"
                 IsVisible="False"
                 BackgroundColor="#80000000"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnDimOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Panel chi tiết -->
        <Border x:Name="itineraryPanel"
                IsVisible="False"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20,20,0,0"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Shadow="{Shadow Brush=Black, Offset='0,-8', Radius=20, Opacity=0.2}">

            <Grid RowDefinitions="Auto, Auto, *, Auto" MaximumHeightRequest="480">

                <!-- Handle bar -->
                <BoxView Grid.Row="0"
                         WidthRequest="40" HeightRequest="4"
                         CornerRadius="2"
                         Color="#E0E0E0"
                         HorizontalOptions="Center"
                         Margin="0,12,0,0"/>

                <!-- Header panel -->
                <Grid Grid.Row="1" ColumnDefinitions="*, Auto"
                      Padding="20,12,12,12">
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="🗺️ Lộ trình"
                               FontSize="12"
                               TextColor="#FF9800"
                               FontAttributes="Bold"/>
                        <Label x:Name="lblOverlayTourName"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#212121"
                               LineBreakMode="TailTruncation"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="✕"
                            BackgroundColor="Transparent"
                            TextColor="#9E9E9E"
                            FontSize="18"
                            WidthRequest="44"
                            HeightRequest="44"
                            Padding="0"
                            Clicked="OnCloseItineraryClicked"/>
                </Grid>

                <!-- Danh sách điểm dừng -->
                <ScrollView Grid.Row="2" Margin="0,0,0,8">
                    <VerticalStackLayout x:Name="itineraryPoiList"
                                         Padding="20,0,20,0"
                                         Spacing="0"/>
                </ScrollView>

                <!-- Nút chọn tour này -->
                <Button Grid.Row="3"
                        x:Name="btnSelectThisTour"
                        Text="📍 Xem trên bản đồ"
                        BackgroundColor="#FF9800"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="52"
                        CornerRadius="0"
                        Margin="0"
                        Padding="0"
                        Clicked="OnSelectTourClicked"
                        Shadow="{Shadow Brush='#FF9800', Offset='0,-4', Radius=10, Opacity=0.25}"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
